{
  "rewrites": [
    {
      "source": "/value-map",
      "destination": "https://zerocheck-report-app.vercel.app/value-map"
    },
    {
      "source": "/value-map/",
      "destination": "https://zerocheck-report-app.vercel.app/value-map/"
    },
    {
      "source": "/value-map/:path*",
      "destination": "https://zerocheck-report-app.vercel.app/value-map/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://zerocheck-report-app.vercel.app/_next/:path*"
    }
  ]
}
